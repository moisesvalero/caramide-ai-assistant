    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.1",
    "husky": "^9.1.7",
    "knip": "^6.23.0",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.71.0",
    "prettier": "^3.9.1",
