    <!-- Footer -->
    <footer class="w-full mt-section-padding-desktop bg-tertiary dark:bg-tertiary-container border-t border-primary">
        <div class="flex flex-col md:flex-row justify-between items-center px-gutter py-margin-safe max-w-[1200px] mx-auto text-on-tertiary">
            <div class="mb-8 md:mb-0">
                <div class="font-headline-lg text-headline-lg text-on-tertiary tracking-tighter mb-4">CARAMIDE SPAIN</div>
