        <!-- Trust Signals / Features -->
        <section class="bg-surface-container-low border-y border-outline-variant">
            <div class="max-w-[1200px] mx-auto py-12 px-gutter grid grid-cols-2 md:grid-cols-4 gap-8">
                <div class="flex flex-col items-center text-center">
                    <span class="material-symbols-outlined text-[32px] mb-3 text-secondary">verified_user</span>
                    <h4 class="font-label-caps text-[11px] uppercase tracking-widest">Dermatológicamente Testado</h4>
                </div>
