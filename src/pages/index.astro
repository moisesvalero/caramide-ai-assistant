---
import '../styles/global.css';
---

<!DOCTYPE html>
<html class="light" lang="es">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <meta name="description" content="Caramide AI Skincare Assistant: Descubre tu rutina de cuidado de la piel personalizada por ciencia clínica e inteligencia artificial." />
    <title>Caramide AI Skincare Assistant | Next Gen Skin Care</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Open Graph / Facebook / WhatsApp / LinkedIn -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://caramide-ai-assistant.vercel.app/" />
    <meta property="og:title" content="Caramide AI Skincare Assistant | Next Gen Skin Care" />
    <meta property="og:description" content="Descubre tu rutina de cuidado de la piel personalizada por ciencia clínica e inteligencia artificial." />
    <meta property="og:image" content="https://caramide-ai-assistant.vercel.app/screen.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://caramide-ai-assistant.vercel.app/" />
    <meta property="twitter:title" content="Caramide AI Skincare Assistant | Next Gen Skin Care" />
    <meta property="twitter:description" content="Descubre tu rutina de cuidado de la piel personalizada por ciencia clínica e inteligencia artificial." />
    <meta property="twitter:image" content="https://caramide-ai-assistant.vercel.app/screen.png" />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;700;800&amp;family=IBM+Plex+Sans:wght@600&amp;family=Cormorant+Garamond:ital,wght@1,300;1,400;1,500;1,600&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        .clinical-shadow {
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.03);
        }
        .hero-gradient {
            background: radial-gradient(circle at top right, #fbf9f9 0%, #efeded 100%);
        }
        .dot-pattern {
            background-image: radial-gradient(#cfc4c5 0.5px, transparent 0.5px);
            background-size: 24px 24px;
        }
        /* Estilos personalizados para el scrollbar */
        .scrollbar-thin::-webkit-scrollbar {
            width: 4px;
        }
        .scrollbar-thin::-webkit-scrollbar-track {
            background: transparent;
        }
        .scrollbar-thin::-webkit-scrollbar-thumb {
            background: #cfc4c5;
            border-radius: 0px;
        }
        .scrollbar-thin::-webkit-scrollbar-thumb:hover {
            background: #7e7576;
        }
    </style>
</head>
<body class="bg-background text-on-background font-body-md selection:bg-secondary selection:text-white">
    <!-- TopNavBar -->
    <header id="main-header" class="w-full top-0 sticky bg-surface dark:bg-surface border-b border-outline-variant dark:border-outline z-50">
        <div class="flex justify-between items-center px-gutter py-4 max-w-[1200px] mx-auto">
            <div class="max-w-[280px] cursor-pointer flex items-center">
                <img src="/logo.png" alt="Caramide Logo" class="h-14 md:h-18 w-auto object-contain" />
            </div>
            <nav class="hidden md:flex items-center space-x-8">
                <a class="font-label-caps text-label-caps uppercase text-primary dark:text-on-surface-variant hover:text-secondary transition-colors duration-200" href="#">CARAMIDE</a>
                <a class="font-label-caps text-label-caps uppercase text-primary dark:text-on-surface-variant hover:text-secondary transition-colors duration-200" href="#">CARAMEDICAL</a>
                <a class="font-label-caps text-label-caps uppercase text-primary dark:text-on-surface-variant hover:text-secondary transition-colors duration-200" href="#">CARAMIDE PRO</a>
                <a class="font-label-caps text-label-caps uppercase text-secondary dark:text-secondary-fixed-dim border-b-2 border-secondary" href="#">PHILOSOPHY</a>
            </nav>
            <div class="flex items-center space-x-6">
                <a href="https://github.com/moisesvalero/caramide-ai-assistant" target="_blank" rel="noopener noreferrer" class="text-primary hover:text-secondary transition-colors duration-200 flex items-center justify-center cursor-pointer" aria-label="Repositorio de GitHub">
                    <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                    </svg>
                </a>
                <button class="cursor-pointer active:opacity-70" aria-label="Ver carrito de compras">
                    <span class="material-symbols-outlined text-primary">shopping_bag</span>
                </button>
                <button class="cursor-pointer active:opacity-70" aria-label="Mi cuenta de usuario">
                    <span class="material-symbols-outlined text-primary">person</span>
                </button>
                <button class="md:hidden cursor-pointer" aria-label="Abrir menú de navegación">
                    <span class="material-symbols-outlined">menu</span>
                </button>
            </div>
        </div>
    </header>

    <main>
        <!-- Hero Section: AI Assistant -->
        <section class="relative min-h-0 md:min-h-[819px] flex flex-col items-center justify-center pt-8 pb-12 md:py-24 px-gutter overflow-hidden hero-gradient">
            <!-- Aurora Lights Background -->
            <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
                <div class="absolute -top-[10%] -left-[10%] w-[50%] h-[50%] rounded-full bg-secondary/5 blur-[120px] animate-aurora-1"></div>
                <div class="absolute -bottom-[10%] -right-[10%] w-[50%] h-[50%] rounded-full bg-secondary/10 blur-[130px] animate-aurora-2"></div>
                <div class="absolute top-[30%] right-[10%] w-[40%] h-[40%] rounded-full bg-outline-variant/10 blur-[100px] animate-aurora-1"></div>
            </div>
            <div class="absolute inset-0 dot-pattern opacity-30 pointer-events-none z-0"></div>
            <div class="relative z-10 max-w-[900px] w-full text-center flex flex-col items-center">
                <span class="inline-block bg-secondary text-white px-3 py-1 font-label-caps text-label-caps mb-6 opacity-0 animate-fade-in-up">AI POWERED DERMATOLOGY</span>
                <h1 class="font-display-lg text-[36px] leading-[44px] md:text-[68px] md:leading-[76px] lg:text-[76px] lg:leading-[84px] text-primary mb-6 opacity-0 animate-fade-in-up animation-delay-100 font-light tracking-tight text-wrap-balance">
                    Tu experto en piel,<br class="hidden md:block"/> potenciado por <span class="font-bold text-secondary">IA</span>.
                </h1>
                <p class="font-body-md text-on-surface-variant md:text-lg mb-8 max-w-[650px] mx-auto opacity-0 animate-fade-in-up animation-delay-200">Cuéntale a nuestra IA qué necesita tu piel y descubre tu rutina personalizada de Caramide al instante.</p>
                
                <!-- Chat Window Container (Initially Hidden, expanded beautifully on first message) -->
                <div id="chat-window" class="hidden w-full max-w-[750px] bg-white border border-primary text-left flex flex-col mb-4 transition-all duration-300">
                    <div class="border-b border-outline-variant px-6 py-3 bg-surface-container-low flex justify-between items-center">
                        <span class="font-label-caps text-label-caps uppercase text-on-surface-variant tracking-wider flex items-center gap-2">
                            <span class="w-2 h-2 bg-secondary animate-pulse inline-block"></span>
                            Caramide AI Skincare Assistant
                        </span>
                        <button id="reset-chat" class="font-label-caps text-[10px] text-outline hover:text-secondary uppercase transition-colors flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">refresh</span> Reiniciar
                        </button>
                    </div>
                    <div id="chat-messages" class="max-h-[350px] overflow-y-auto px-6 py-4 flex flex-col gap-4 scrollbar-thin">
                        <!-- Los mensajes de la conversación se cargarán aquí dinámicamente -->
                    </div>
                    
                    <!-- Typying status -->
                    <div id="chat-typing" class="hidden px-6 py-3 border-t border-outline-variant bg-surface-container-lowest flex gap-4 items-center animate-pulse">
                        <span class="material-symbols-outlined text-outline animate-spin text-lg">autorenew</span>
                        <span class="font-label-caps text-[11px] uppercase tracking-wider text-outline">Analizando tu perfil clínico...</span>
                    </div>
                </div>

                <!-- AI Composer Box -->
                <div class="w-full max-w-[750px] bg-white border border-outline-variant focus-within:border-primary p-1.5 md:p-2 group transition-all duration-300 opacity-0 animate-fade-in-up animation-delay-300">
                    <div class="flex flex-row items-center justify-between gap-2">
                        <div class="flex-1 px-2 py-1 flex items-center gap-3 min-w-0">
                            <span class="material-symbols-outlined text-outline flex-shrink-0 text-[20px] md:text-[24px]">auto_awesome</span>
                            <label for="chat-input" class="sr-only">Dime qué necesita tu piel</label>
                            <input id="chat-input" class="w-full bg-transparent border-none focus:outline-none focus:ring-0 focus-visible:outline-none outline-none text-body-md font-body-md text-on-surface placeholder:text-outline/60 min-w-0" placeholder="Dime qué necesita tu piel (ej. 'tengo piel grasa')...." type="text"/>
                        </div>
                        <button id="chat-send" class="w-10 h-10 md:w-11 md:h-11 flex-shrink-0 bg-primary text-on-primary hover:scale-[1.03] active:scale-[0.97] transition-all duration-200 flex items-center justify-center cursor-pointer" aria-label="Enviar consulta">
                            <span class="material-symbols-outlined text-[18px] md:text-[20px]">send</span>
                        </button>
                    </div>
                </div>

                <!-- Prompt Examples -->
                <div class="mt-8 flex flex-wrap justify-center gap-3 opacity-0 animate-fade-in-up animation-delay-300">
                    <button class="prompt-chip px-4 py-2 border border-outline-variant hover:border-primary hover:scale-105 active:scale-95 transition-all duration-200 font-label-caps text-[10px] uppercase tracking-widest text-on-surface-variant">Antiarrugas</button>
                    <button class="prompt-chip px-4 py-2 border border-outline-variant hover:border-primary hover:scale-105 active:scale-95 transition-all duration-200 font-label-caps text-[10px] uppercase tracking-widest text-on-surface-variant">Piel Grasa</button>
                    <button class="prompt-chip px-4 py-2 border border-outline-variant hover:border-primary hover:scale-105 active:scale-95 transition-all duration-200 font-label-caps text-[10px] uppercase tracking-widest text-on-surface-variant">Hidratación profunda</button>
                    <button class="prompt-chip px-4 py-2 border border-outline-variant hover:border-primary hover:scale-105 active:scale-95 transition-all duration-200 font-label-caps text-[10px] uppercase tracking-widest text-on-surface-variant">Manchas Solares</button>
                </div>
            </div>
            <!-- Background Aesthetic Element -->
            <div class="absolute -bottom-20 left-1/2 -translate-x-1/2 w-full max-w-[1200px] h-64 opacity-10 pointer-events-none"></div>
        </section>

        <!-- Product Grid: Recommended Bestsellers -->
        <section class="max-w-[1200px] mx-auto py-section-padding-desktop px-gutter">
            <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
                <div>
                    <h2 class="font-headline-lg text-headline-lg uppercase tracking-tight text-primary">Nuestros Best-Sellers</h2>
