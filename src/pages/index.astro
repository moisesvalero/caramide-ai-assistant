    <script>
        // Array to hold chat messages history
        let chatMessages = [];
        
        const chatWindow = document.getElementById('chat-window');
        const chatMessagesDiv = document.getElementById('chat-messages');
        const chatInput = document.getElementById('chat-input');
        const chatSend = document.getElementById('chat-send');
        const chatTyping = document.getElementById('chat-typing');
        const resetChatBtn = document.getElementById('reset-chat');
        const promptChips = document.querySelectorAll('.prompt-chip');

        // Event Listeners
        chatInput.addEventListener('focus', () => {
            chatInput.parentElement.parentElement.classList.add('ring-2', 'ring-secondary/20');
        });

        chatInput.addEventListener('blur', () => {
            chatInput.parentElement.parentElement.classList.remove('ring-2', 'ring-secondary/20');
        });

        chatInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                sendMessage();
            }
        });

        chatSend.addEventListener('click', sendMessage);

        resetChatBtn.addEventListener('click', resetChat);

        promptChips.forEach(chip => {
            chip.addEventListener('click', () => {
                const promptText = chip.textContent.trim();
                let fullPrompt = "";
                if (promptText === "Piel Grasa") {
                    fullPrompt = "Tengo la piel grasa y me salen brillos, ¿qué me recomiendas?";
                } else if (promptText === "Antiarrugas") {
                    fullPrompt = "Busco un tratamiento antiarrugas potente, ¿qué tenéis?";
                } else if (promptText === "Hidratación profunda") {
                    fullPrompt = "Tengo la piel deshidratada y tirante, ¿cómo la hidrato?";
                } else if (promptText === "Manchas Solares") {
                    fullPrompt = "Me han salido manchas del sol en la cara, ¿cómo las reduzco?";
                } else {
                    fullPrompt = promptText;
                }
                
                chatInput.value = fullPrompt;
                sendMessage();
            });
        });

        // Functions
        function formatReply(text) {
            // Escape basic HTML
            let escaped = text
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;");
            
            // Bold markdown: **text** -> <strong>text</strong>
            escaped = escaped.replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>");
            
            // List items: - item -> <li>item</li>
            escaped = escaped.replace(/^\s*-\s*(.*?)$/gm, "• $1");
            
            // Line breaks
            escaped = escaped.replace(/\n/g, "<br>");
            
            return escaped;
        }

        function resetChat() {
            chatMessages = [];
            chatMessagesDiv.innerHTML = `
                <div class="flex gap-4 items-start">
                    <span class="material-symbols-outlined text-secondary bg-surface-container-low border border-outline-variant p-2 text-lg">auto_awesome</span>
                    <div class="flex-1 bg-surface-container-lowest border border-outline-variant p-4 text-on-surface text-[15px] leading-relaxed">
                        <p class="mb-2"><strong>¡Hola!</strong> Soy tu asesor de dermatología Caramide.</p>
                        <p>Dime qué tipo de piel tienes o qué inquietud quieres tratar (arrugas, imperfecciones, manchas, hidratación) y te diseñaré una rutina clínica personalizada con nuestros productos oficiales.</p>
                    </div>
                </div>
            `;
            chatWindow.classList.add('hidden');
            chatInput.value = "";
        }

        async function sendMessage() {
            if (chatSend.disabled) return;

            const query = chatInput.value.trim();
            if (!query) return;

            // Clear input
            chatInput.value = "";

            // Show chat window if hidden
            if (chatWindow.classList.contains('hidden')) {
                chatWindow.classList.remove('hidden');
                chatWindow.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }

            // Append user message to UI
            appendMessage('user', query);
            
            // Save to messages history
            chatMessages.push({ role: 'user', content: query });

            // Show typing indicator
            chatTyping.classList.remove('hidden');
            chatMessagesDiv.scrollTop = chatMessagesDiv.scrollHeight;

            // Change button state
            chatSend.disabled = true;
            chatSend.innerHTML = `Analizando... <span class="material-symbols-outlined animate-spin text-[18px]">autorenew</span>`;

            try {
                const response = await fetch('/api/chat', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ messages: chatMessages })
                });

                const data = await response.json();
                
                // Hide typing indicator
                chatTyping.classList.add('hidden');

                if (response.ok && data.reply) {
                    appendMessage('assistant', data.reply);
                    chatMessages.push({ role: 'assistant', content: data.reply });
                } else {
                    const errMsg = data.error || 'Ocurrió un error al procesar tu solicitud.';
                    appendMessage('error', errMsg);
                }
            } catch (error) {
                chatTyping.classList.add('hidden');
                appendMessage('error', 'Error de conexión con el servidor. Por favor, inténtalo de nuevo.');
                console.error('Chat error:', error);
            } finally {
                // Restore button state
                chatSend.disabled = false;
                chatSend.innerHTML = `Analizar <span class="material-symbols-outlined">arrow_forward</span>`;
                chatMessagesDiv.scrollTop = chatMessagesDiv.scrollHeight;
            }
        }

        function appendMessage(sender, text) {
            const messageDiv = document.createElement('div');
            messageDiv.className = 'flex gap-4 items-start';

            if (sender === 'user') {
                messageDiv.innerHTML = `
                    <span class="material-symbols-outlined text-primary bg-surface-container-low border border-outline-variant p-2 text-lg">person</span>
                    <div class="flex-1 bg-surface-container-low border border-outline-variant p-4 text-on-surface text-[15px] leading-relaxed">
                        <strong>Tú:</strong><br>
                        ${text}
                    </div>
                `;
            } else if (sender === 'assistant') {
                messageDiv.innerHTML = `
                    <span class="material-symbols-outlined text-secondary bg-surface-container-low border border-outline-variant p-2 text-lg">auto_awesome</span>
                    <div class="flex-1 bg-surface-container-lowest border border-outline-variant p-4 text-on-surface text-[15px] leading-relaxed">
                        <strong>Caramide AI Assistant:</strong><br>
                        <div class="mt-2">${formatReply(text)}</div>
                    </div>
                `;
            } else if (sender === 'error') {
                messageDiv.innerHTML = `
                    <span class="material-symbols-outlined text-error bg-error-container p-2 text-lg">warning</span>
                    <div class="flex-1 bg-error-container border border-error p-4 text-error text-[15px] leading-relaxed">
                        <strong>Sistema:</strong><br>
                        ${text}
                    </div>
                `;
            }

            chatMessagesDiv.appendChild(messageDiv);
            chatMessagesDiv.scrollTop = chatMessagesDiv.scrollHeight;
        }
    </script>
</body>
</html>
